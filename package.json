{
  "name": "node-red-contrib-spreadsheet",
  "version": "1.0.0",
  "description": "Enhanced Node-RED nodes to read data from spreadsheet (Excel, ODS, etc.) files with dynamic sheet name selection via msg.sheetName.",
  "main": "node.js",
  "scripts": {
    "test": "mocha \"test/**/*_spec.js\""
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/lordnetro/node-red-contrib-spreadsheet.git"
  },
  "keywords": [
    "node-red",
    "spreadsheet",
    "excel",
    "ods",
    "sheet",
    "dynamic-sheet"
  ],
  "author": "Marc Ortiz Lopez",
  "license": "Apache-2.0",
  "bugs": {
    "url": "https://github.com/lordnetro/node-red-contrib-spreadsheet/issues"
  },
  "homepage": "https://github.com/lordnetro/node-red-contrib-spreadsheet#readme",
  "node-red": {
    "nodes": {
      "book": "book.js",
      "sheet": "sheet.js",
      "cell": "cell.js",
      "sheet-to-json": "sheet-to-json.js"
    }
  },
  "dependencies": {
    "xlsx": "https://cdn.sheetjs.com/xlsx-0.19.3/xlsx-0.19.3.tgz"
  },
  "devDependencies": {
    "mocha": "^8.2.1",
    "node-red": "^1.2.6",
    "node-red-node-test-helper": "^0.2.5",
    "should": "^13.2.3"
  }
}
